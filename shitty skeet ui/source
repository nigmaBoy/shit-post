            if Library.CurrentPopup and Library.CurrentPopup.Open then
                if Library.CurrentPopup.Frame  and Utility:IsMouseOverFrame(Library.CurrentPopup.Frame)  then return end
                if Library.CurrentPopup.Button and Utility:IsMouseOverFrame(Library.CurrentPopup.Button) then return end
                if not Utility:IsMouseOverFrame(MainFrame) then
                    Library.CurrentPopup:Close()
                end
            end
        end
    end)

