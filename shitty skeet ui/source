                            if s and decoded then
                                for flag, value in pairs(decoded) do
                                    local obj = Library.Flags[flag]
                                    if obj then
                                        if type(value) == "table" and value.R then
                                            obj:Set(Color3.new(value.R, value.G, value.B), value.Alpha)
                                        elseif type(value) == "string" and obj.Key then
                                            local parsed = parseKey(value)
                                            if parsed then obj:Set(parsed) end
                                        else
                                            obj:Set(value)
                                        end
                                    end
                                end
                            end
                        end
                    end, 5)

                    AddCfgButton("Export Clipboard", function()
                        local name = ConfigSystem.Selected
                        if name and isfile("gamesense/configs/" .. name .. ".txt") then
                            local content = readfile("gamesense/configs/" .. name .. ".txt")
                            if setclipboard then setclipboard(content) end
                        end
                    end, 6)

                    ConfigSystem:Refresh()
                    return ConfigSystem
                end

                -- // SYSTEM: SCRIPT RUNNER // --
                function Section:CreateScriptSystem()
                    local ScriptSystem = { Selected = nil }

                    local SectionList = Scroll:FindFirstChildOfClass("UIListLayout")
                    if SectionList then
                        SectionList.HorizontalAlignment = Enum.HorizontalAlignment.Center
                    end
                    local SectionPad = Scroll:FindFirstChildOfClass("UIPadding")
                    if SectionPad then
                        SectionPad.PaddingLeft = UDim.new(0, 0)
                    end

                    local ScriptContainer = Utility:Create("Frame", {
                        Parent             = Scroll,
                        Size               = UDim2.new(0.75, 0, 0, 0),
                        AutomaticSize      = Enum.AutomaticSize.Y,
                        BackgroundTransparency = 1,
                    })
                    Utility:Create("UIListLayout", {
                        Parent    = ScriptContainer,
                        Padding   = UDim.new(0, 10),
                        SortOrder = Enum.SortOrder.LayoutOrder,
                    })

                    local SListOuter = Utility:Create("Frame", {
                        Parent           = ScriptContainer,
                        Size             = UDim2.new(1, 0, 0, 200),
                        BackgroundColor3 = Color3.fromRGB(12, 12, 12),
                        BorderSizePixel  = 1,
                        BorderColor3     = Color3.fromRGB(35, 35, 35),
                    })
                    local SListInner = Utility:Create("ScrollingFrame", {
                        Parent                 = SListOuter,
                        Size                   = UDim2.new(1, 0, 1, 0),
                        BackgroundColor3       = Color3.fromRGB(28, 28, 28),
                        BorderSizePixel        = 0,
                        ScrollBarThickness     = 2,
                        ScrollBarImageColor3   = Library.Accent,
                        CanvasSize             = UDim2.new(0, 0, 0, 0),
                        AutomaticCanvasSize    = Enum.AutomaticSize.Y,
                    })
                    Utility:Create("UIListLayout", { Parent = SListInner, SortOrder = Enum.SortOrder.LayoutOrder })
                    Utility:Create("UIPadding", { Parent = SListInner, PaddingTop = UDim.new(0, 1), PaddingBottom = UDim.new(0, 1) })

                    local SBtnContainer = Utility:Create("Frame", {
                        Parent             = ScriptContainer,
                        Size               = UDim2.new(1, 0, 0, 0),
                        AutomaticSize      = Enum.AutomaticSize.Y,
                        BackgroundTransparency = 1,
                    })
                    Utility:Create("UIListLayout", {
                        Parent             = SBtnContainer,
                        Padding            = UDim.new(0, 8),
                        HorizontalAlignment = Enum.HorizontalAlignment.Center,
                    })

                    local function AddScriptBtn(name, callback)
                        local BtnFrame = Utility:Create("Frame", {
                            Parent           = SBtnContainer,
                            Size             = UDim2.new(1, 0, 0, 22),
                            BackgroundColor3 = Color3.fromRGB(30, 30, 30),
                            BorderColor3     = Color3.fromRGB(10, 10, 10),
                            BorderSizePixel  = 1,
                        })
                        Utility:Create("TextLabel", {
                            Parent             = BtnFrame,
                            Size               = UDim2.new(1, 0, 1, 0),
                            BackgroundTransparency = 1,
                            Text               = name,
                            Font               = Enum.Font.Code,
                            TextSize           = 11,
                            TextColor3         = Color3.fromRGB(205, 205, 205),
                        })
                        local BtnInteract = Utility:Create("TextButton", {
                            Parent             = BtnFrame,
                            Size               = UDim2.new(1, 0, 1, 0),
                            BackgroundTransparency = 1,
                            Text               = "",
                        })
                        Utility:Connect(BtnInteract.MouseEnter, function() BtnFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40) end)
                        Utility:Connect(BtnInteract.MouseLeave, function() BtnFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30) end)
                        Utility:Connect(BtnInteract.MouseButton1Click, callback)
                    end

                    function ScriptSystem:Refresh()
                        for _, v in pairs(SListInner:GetChildren()) do
                            if v:IsA("TextButton") then v:Destroy() end
                        end
                        if not isfolder("gamesense/scripts") then makefolder("gamesense/scripts") end

                        local files = listfiles("gamesense/scripts")
                        for _, file in pairs(files) do
                            local name = file:match("([^/\\]+)%.txt$") or file:match("([^/\\]+)%.lua$")
                            if name then
                                local btn = Utility:Create("TextButton", {
                                    Parent             = SListInner,
                                    Size               = UDim2.new(1, 0, 0, 15),
                                    BackgroundTransparency = 1,
                                    Text               = "  " .. name,
                                    Font               = Enum.Font.Code,
                                    TextSize           = 11,
                                    TextColor3         = (ScriptSystem.Selected == file and Library.Accent or Color3.fromRGB(205, 205, 205)),
                                    TextXAlignment     = Enum.TextXAlignment.Left,
                                    BorderSizePixel    = 0,
                                })
                                if ScriptSystem.Selected == file then
                                    btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
                                    btn.BackgroundTransparency = 0
                                end
                                Utility:Connect(btn.MouseButton1Click, function()
                                    ScriptSystem.Selected = file
                                    ScriptSystem:Refresh()
                                end)
                            end
                        end
                    end

                    AddScriptBtn("Execute", function()
                        if ScriptSystem.Selected and isfile(ScriptSystem.Selected) then
                            local ok, err = pcall(function()
                                loadstring(readfile(ScriptSystem.Selected))()
                            end)
                            if not ok then warn("gamesense script error:", err) end
                        end
                    end)

                    AddScriptBtn("Refresh", function() ScriptSystem:Refresh() end)

                    ScriptSystem:Refresh()
                    return ScriptSystem
                end

                return Section
            end -- Interface:CreateSection

            return Interface
        end -- Page:CreateSharedLogic

        return Page
    end -- BuildPage

    -- // PUBLIC: CreatePage // --
    -- Creates a normal tab, stacked top-to-bottom in the sidebar.
    function Window:CreatePage(props)
        Library.TabCount = Library.TabCount + 1
        local Page = BuildPage(props, TabHolder, Library.TabCount)

        if #Window.Pages == 0 then
            Page:Show()
        else
            Page:DeactivateVisuals()
        end

        table.insert(Window.Pages, Page)
        return Page
    end

    -- // AUTO CONFIG TAB (always pinned at bottom) // --
    -- Built with a fixed layout order of 9999 so it always sorts last.
    -- It is constructed after a short defer so all user pages are built first,
    -- meaning JumpTo(first page) has already been called and the config tab
    -- won't steal the initial view.
    task.defer(function()
        local ConfigPage = BuildPage({
            Icon = "rbxassetid://15453364412",
            Name = "Config",
        }, ConfigTabHolder, 9999)

        -- If no user page existed at all, show this one; otherwise keep it deactivated
        if #Window.Pages == 0 then
            ConfigPage:Show()
            Window.ActivePage = ConfigPage
        else
            ConfigPage:DeactivateVisuals()
        end

        Window._ConfigPage = ConfigPage

        -- Left sub-tab: Presets
        local MainSubTab = ConfigPage:CreateSubTab({ Name = "Presets" })
        local ConfigSection = MainSubTab:CreateSection({ Name = "Configs", Side = "Left", Size = 450 })
        ConfigSection:CreateConfigSystem()

        -- Right sub-tab: Scripts
        local ScriptSubTab = ConfigPage:CreateSubTab({ Name = "Scripts" })
        local ScriptSection = ScriptSubTab:CreateSection({ Name = "Lua Scripts", Side = "Left", Size = 450 })
        ScriptSection:CreateScriptSystem()

        -- Third sub-tab: GUI settings (keybind, accent, unload)
        local GUISubTab = ConfigPage:CreateSubTab({ Name = "GUI" })
        local GUISection = GUISubTab:CreateSection({ Name = "Interface", Side = "Left", Size = 150 })

        GUISection:CreateKeybind({
            Name     = "Menu Keybind",
            Default  = Window.Keybind,
            Flag     = "gs_MenuKeybind",
            Callback = function(k) Window.Keybind = k end,
        })

        GUISection:CreateColorpicker({
            Name         = "Accent Color",
            DefaultColor = Library.Accent,
            Flag         = "gs_AccentColor",
            Callback     = function(c)
                Library.Accent = c
                -- Propagate to all flag objects that hold a live state colour
                for _, obj in pairs(Library.Flags) do
                    if type(obj) == "table" and obj.Set and obj.State ~= nil then
                        obj:Set(obj.State)
                    end
                end
            end,
        })

        GUISection:CreateButton({
            Name     = "Unload",
            Callback = function() Window:Unload() end,
        })
    end)

    Library._Window = Window
    return Window
end

-- Export
getgenv().gamesense = Library
return Library
