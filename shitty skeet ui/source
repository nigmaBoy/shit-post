                        if Library.CurrentPopup and Library.CurrentPopup ~= Drop then
                            Library.CurrentPopup:Close()
                        end
                        Drop.Open            = true
                        Library.CurrentPopup = Drop
                        Drop:Refresh()
                        ListFrame.Visible    = true
                        Shield.Visible       = true
                        local absPos = Outer.AbsolutePosition
                        local mainPos = MainFrame.AbsolutePosition
                        ListFrame.Position = UDim2.new(
                            0, absPos.X - mainPos.X,
                            0, (absPos.Y - mainPos.Y) + 21
