                    local AlphaFrame = Utility:Create("Frame", {Parent = PickerInner, Position = UDim2.new(0, 5, 0, 160), Size = UDim2.new(0, 150, 0, 12), BackgroundColor3 = Color3.new(1,1,1), BorderColor3 = Color3.new(0,0,0), ZIndex = 51, Active = true})
                    Utility:Create("ImageLabel", {Parent = AlphaFrame, Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Image = "rbxassetid://3887014957", ScaleType = Enum.ScaleType.Tile, TileSize = UDim2.new(0,8,0,8), ZIndex = 52})
                    local AlphaGradientFrame = Utility:Create("Frame", {Parent = AlphaFrame, Size = UDim2.new(1,0,1,0), BackgroundColor3 = Color3.new(1,1,1), BackgroundTransparency = 0, ZIndex = 53})
                    local AlphaGradient = Utility:Create("UIGradient", {Parent = AlphaGradientFrame, Transparency = NumberSequence.new(1, 0)}) 
                    
                    local SVMarker = Utility:Create("Frame", {Parent = SV, Size = UDim2.new(0, 4, 0, 4), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundColor3 = Color3.new(1,1,1), BorderColor3 = Color3.new(0,0,0), ZIndex = 55})
                    local HueMarker = Utility:Create("Frame", {Parent = Hue, Size = UDim2.new(1, 0, 0, 2), BackgroundColor3 = Color3.new(1,1,1), BorderColor3 = Color3.new(0,0,0), ZIndex = 55})
                    local AlphaMarker = Utility:Create("Frame", {Parent = AlphaFrame, Size = UDim2.new(0, 2, 1, 0), BackgroundColor3 = Color3.new(1,1,1), BorderColor3 = Color3.new(0,0,0), ZIndex = 55})
                    
                    local h, s, v = Color3.toHSV(ColorP.State)
                    local dragSV, dragHue, dragAlpha = false, false, false

                    local function Update()
                        ColorP.State = Color3.fromHSV(h, s, v)
                        Preview.BackgroundColor3 = ColorP.State
                        SV.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                        AlphaGradientFrame.BackgroundColor3 = ColorP.State
                        
                        if props.Callback then props.Callback(ColorP.State, ColorP.Alpha) end
                        
                        if hostFlag then
                            Library.ConfigValues[hostFlag] = {
                                R = ColorP.State.R, G = ColorP.State.G, B = ColorP.State.B, Alpha = ColorP.Alpha
                            }
                        end
                    end
                    
                    function ColorP:Set(col, alph)
                        ColorP.State = col
                        ColorP.Alpha = alph
                        h, s, v = Color3.toHSV(col)
                        SVMarker.Position = UDim2.new(s, 0, 1 - v, 0)
                        HueMarker.Position = UDim2.new(0, 0, 1 - h, 0)
                        AlphaMarker.Position = UDim2.new(alph, 0, 0, 0)
                        Update()
                    end

                    function ColorP:Close()
                        ColorP.Open = false
                        PickerFrame.Visible = false
                        Shield.Visible = false
                        Library.CurrentPopup = nil
                        Library.Interacting = false
                    end
                    
                    ColorP.Frame = PickerFrame
                    ColorP.Button = HostButton
                    
                    Utility:Connect(HostButton.MouseButton1Click, function()
                        if Library.CurrentPopup and Library.CurrentPopup ~= ColorP then Library.CurrentPopup:Close() end
                        ColorP.Open = not ColorP.Open
                        if ColorP.Open then
                            Library.CurrentPopup = ColorP
                            PickerFrame.Visible = true
                            Shield.Visible = true
                            local absPos = HostButton.AbsolutePosition
                            local absSize = HostButton.AbsoluteSize
                            local pickerX = absPos.X - MainFrame.AbsolutePosition.X
                            local pickerY = (absPos.Y - MainFrame.AbsolutePosition.Y) + absSize.Y + 4
                            if (pickerX + 182) > MainFrame.AbsoluteSize.X then pickerX = pickerX - (182 - absSize.X) end
                            PickerFrame.Position = UDim2.new(0, pickerX, 0, pickerY)
                        else ColorP:Close() end
                    end)
                    
                    Utility:Connect(SV.InputBegan, function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragSV = true; Library.Interacting = true end end)
                    Utility:Connect(Hue.InputBegan, function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragHue = true; Library.Interacting = true end end)
                    Utility:Connect(AlphaFrame.InputBegan, function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragAlpha = true; Library.Interacting = true end end)
                    
                    Utility:Connect(UserInputService.InputEnded, function(inp) 
                        if inp.UserInputType == Enum.UserInputType.MouseButton1 then 
                            dragSV, dragHue, dragAlpha = false, false, false 
                            Library.Interacting = false 
                        end 
                    end)
                    
                    Utility:Connect(UserInputService.InputChanged, function(inp)
                        if inp.UserInputType == Enum.UserInputType.MouseMovement then
                            if dragSV then
                                s = math.clamp((inp.Position.X - SV.AbsolutePosition.X) / SV.AbsoluteSize.X, 0, 1)
                                v = 1 - math.clamp((inp.Position.Y - SV.AbsolutePosition.Y) / SV.AbsoluteSize.Y, 0, 1)
                                SVMarker.Position = UDim2.new(s, 0, 1-v, 0)
                                Update()
                            elseif dragHue then
                                local y = math.clamp((inp.Position.Y - Hue.AbsolutePosition.Y) / Hue.AbsoluteSize.Y, 0, 1)
                                h = 1 - y
                                HueMarker.Position = UDim2.new(0, 0, y, 0)
                                Update()
                            elseif dragAlpha then
                                local x = math.clamp((inp.Position.X - AlphaFrame.AbsolutePosition.X) / AlphaFrame.AbsoluteSize.X, 0, 1)
                                ColorP.Alpha = x 
                                AlphaMarker.Position = UDim2.new(x, 0, 0, 0)
                                Update()
                            end
                        end
                    end)

                    Update()
                    return ColorP
                end

