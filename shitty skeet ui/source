                    }
                    local Frame = Utility:Create("Frame", {Parent = Scroll, Size = UDim2.new(1, 0, 0, 40), BackgroundTransparency = 1})
                    Utility:Create("TextLabel", {Parent = Frame, Position = UDim2.new(0, 41, 0, 0), Size = UDim2.new(1, -41, 0, 15), BackgroundTransparency = 1, Text = props.Name, Font = Enum.Font.Code, TextSize = 11, TextColor3 = Color3.fromRGB(205, 205, 205), TextXAlignment = Enum.TextXAlignment.Left})
                    
                    local MinusBtn = Utility:Create("TextButton", {Parent = Frame, Position = UDim2.new(0, 25, 0, 12), Size = UDim2.new(0, 10, 0, 10), BackgroundTransparency = 1, Text = "-", Font = Enum.Font.Code, TextSize = 12, TextColor3 = Color3.fromRGB(155, 155, 155), ZIndex = 5})
                    local PlusBtn = Utility:Create("TextButton", {Parent = Frame, Position = UDim2.new(1, -45, 0, 12), Size = UDim2.new(0, 10, 0, 10), BackgroundTransparency = 1, Text = "+", Font = Enum.Font.Code, TextSize = 12, TextColor3 = Color3.fromRGB(155, 155, 155), ZIndex = 5})

                    local Outer = Utility:Create("Frame", {Parent = Frame, Position = UDim2.new(0, 40, 0, 15), Size = UDim2.new(1, -90, 0, 7), BackgroundColor3 = Color3.fromRGB(12, 12, 12), BorderSizePixel = 0})
                    local Inner = Utility:Create("Frame", {Parent = Outer, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), BackgroundColor3 = Color3.fromRGB(71, 71, 71), BorderSizePixel = 0})
                    local Fill = Utility:Create("Frame", {Parent = Inner, Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = Library.Accent, BorderSizePixel = 0})
                    local ValueBox = Utility:Create("TextBox", {Parent = Frame, Position = UDim2.new(0.5, -5, 0, 25), AnchorPoint = Vector2.new(0.5, 0), Size = UDim2.new(0, 0, 0, 15), BackgroundTransparency = 1, Text = "", Font = Enum.Font.Code, TextSize = 11, TextColor3 = Color3.fromRGB(255, 255, 255), ClearTextOnFocus = false, ZIndex = 5, TextXAlignment = Enum.TextXAlignment.Center})
                    local Button = Utility:Create("TextButton", {Parent = Frame, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 1})
                    
                    local Dragging = false
                    function Slider:Set(val)
                        val = math.clamp(val, Slider.Min, Slider.Max)
                        if Slider.Step then val = math.floor(val / Slider.Step + 0.5) * Slider.Step end
                        val = tonumber(string.format("%." .. Slider.Decimals .. "f", val))
                        Slider.State = val
                        
                        TweenService:Create(Fill, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                            Size = UDim2.new((val - Slider.Min) / (Slider.Max - Slider.Min), 0, 1, 0)
                        }):Play()
                        
                        ValueBox.Text = string.format("%."..(props.Decimals == 0 and "0" or "1").."f", val)..(props.Suffix or "")
                        local txtSize = Utility:GetTextSize(ValueBox.Text, ValueBox.Font, ValueBox.TextSize)
                        ValueBox.Size = UDim2.new(0, txtSize.X + 10, 0, 15)
                        Slider.Callback(val)
                        if props.Flag then Library.ConfigValues[props.Flag] = val end
                    end

                    Utility:Connect(MinusBtn.MouseButton1Click, function() Slider:Set(Slider.State - Slider.Step) end)
                    Utility:Connect(PlusBtn.MouseButton1Click, function() Slider:Set(Slider.State + Slider.Step) end)
                    Utility:Connect(ValueBox.FocusLost, function()
                        local n = tonumber(ValueBox.Text)
                        if n then Slider:Set(n) else Slider:Set(Slider.State) end
                    end)
                    
                    Utility:Connect(Button.MouseButton1Down, function()
                        Library.Interacting = true
                        Dragging = true
                        Slider:Set(Slider.Min + (Slider.Max - Slider.Min) * math.clamp((UserInputService:GetMouseLocation().X - Inner.AbsolutePosition.X) / Inner.AbsoluteSize.X, 0, 1))
                    end)
                    Utility:Connect(UserInputService.InputEnded, function(input) 
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then 
                            Dragging = false
                            Library.Interacting = false 
                        end 
                    end)
                    Utility:Connect(UserInputService.InputChanged, function(input) 
                        if Dragging and input.UserInputType == Enum.UserInputType.MouseMovement then 
                            Slider:Set(Slider.Min + (Slider.Max - Slider.Min) * math.clamp((input.Position.X - Inner.AbsolutePosition.X) / Inner.AbsoluteSize.X, 0, 1)) 
                        end 
                    end)
                    
                    if props.Flag then
                        Library.Flags[props.Flag] = Slider
                        Library.ConfigValues[props.Flag] = Slider.State
                    end
                    Slider:Set(Slider.State)
                    return Slider
                end

