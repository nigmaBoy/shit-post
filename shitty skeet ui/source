                                local deltaY = currentMouse.Y - dragOrigin.Y
                                
                                if math.abs(deltaX) >= snapGrid or math.abs(deltaY) >= snapGrid then
                                    local addX = math.floor(deltaX / snapGrid) * snapGrid
                                    local addY = math.floor(deltaY / snapGrid) * snapGrid
                                    
                                    local newWidth = math.max(120, startSize.X + addX)
                                    local newHeight = math.max(80, startSize.Y + addY)
                                    
                                    local currentHeight = Holder.Size.Y.Offset
                                    local deltaHeight = newHeight - currentHeight
                                    
                                    if deltaHeight ~= 0 then
                                        for _, otherSection in pairs(Interface.Sections) do
                                            if otherSection.Frame ~= Holder then
                                                local isBelow = otherSection.Frame.Position.Y.Offset > Holder.Position.Y.Offset
                                                local isSameColumn = math.abs(otherSection.Frame.Position.X.Offset - Holder.Position.X.Offset) < 50
                                                
                                                if isBelow and isSameColumn then
                                                    otherSection.Frame.Position = UDim2.new(
                                                        0, otherSection.Frame.Position.X.Offset,
                                                        0, otherSection.Frame.Position.Y.Offset + deltaHeight
                                                    )
                                                end
                                            end
                                        end
                                    end
                                    
                                    Holder.Size = UDim2.new(0, newWidth, 0, newHeight)
                                end
                            end
                        end)
                        
                        local endConn; endConn = UserInputService.InputEnded:Connect(function(inputEnd)
                            if inputEnd.UserInputType == Enum.UserInputType.MouseButton1 then
                                isDragging = false
                                Library.Interacting = false
                                if conn then conn:Disconnect() end
                                if endConn then endConn:Disconnect() end
                            end
                        end)
                    end
                end)

                -- MOVING & SWAPPING LOGIC
                Holder.InputBegan:Connect(function(input, gpe)
                    if gpe then return end
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        local absolutePosition = TitleText.AbsolutePosition
                        local mouseLocation = UserInputService:GetMouseLocation()
                        
                        if mouseLocation.Y - absolutePosition.Y < 25 then
                            local dragOrigin = UserInputService:GetMouseLocation()
                            local startPos = { X = Holder.Position.X.Offset, Y = Holder.Position.Y.Offset }
                            isMoving = true
                            Library.Interacting = true

                            local conn; conn = UserInputService.InputChanged:Connect(function(inputChange)
                                if isMoving and inputChange.UserInputType == Enum.UserInputType.MouseMovement then
                                    local currentMouse = UserInputService:GetMouseLocation()
                                    local deltaX = currentMouse.X - dragOrigin.X
                                    local deltaY = currentMouse.Y - dragOrigin.Y
                                    
                                    if math.abs(deltaX) >= snapGrid or math.abs(deltaY) >= snapGrid then
                                        local addX = math.floor(deltaX / snapGrid) * snapGrid
                                        local addY = math.floor(deltaY / snapGrid) * snapGrid
                                        
                                        Holder.Position = UDim2.new(0, startPos.X + addX, 0, startPos.Y + addY)

                                        for _, otherSection in pairs(Interface.Sections) do
                                            if otherSection.Frame == Holder then continue end
                                            if collidesWith(otherSection.Frame, Holder) then
                                                local oldSize = otherSection.Frame.Size
                                                local oldPos = otherSection.Frame.Position
                                                
                                                otherSection.Frame.Position = UDim2.new(0, startPos.X, 0, startPos.Y)
                                                otherSection.Frame.Size = Holder.Size
                                                
                                                Holder.Size = oldSize
                                                
                                                startPos = { X = oldPos.X.Offset, Y = oldPos.Y.Offset }
                                                dragOrigin = currentMouse
                                                break
                                            end
                                        end
                                    end
                                end
                            end)
                            
                            local endConn; endConn = UserInputService.InputEnded:Connect(function(inputEnd)
                                if inputEnd.UserInputType == Enum.UserInputType.MouseButton1 then
                                    isMoving = false
                                    Library.Interacting = false
                                    if conn then conn:Disconnect() end
                                    if endConn then endConn:Disconnect() end
                                end
                            end)
                        end
                    end
                end)

