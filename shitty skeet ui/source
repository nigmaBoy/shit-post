                function Section:CreateSlider(props)
                    local Slider = {
                        State = props.Default or props.Min, 
                        Default = props.Default or props.Min,
                        Min = props.Min or 0, Max = props.Max or 100, 
                        Decimals = props.Decimals or 1, 
                        Step = props.Step or 1,
