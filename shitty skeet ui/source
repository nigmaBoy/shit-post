                    Parent           = Interface.Layer,
                    Size             = UDim2.new(0, 256, 0, secH),
                    Position         = UDim2.new(0, xOff, 0, yOff),
                    BackgroundColor3 = Color3.fromRGB(12, 12, 12),
                    BorderSizePixel  = 0,
                })

                if isRight then
                    Interface.RightY = Interface.RightY + secH + 12
                else
                    Interface.LeftY  = Interface.LeftY  + secH + 12
                end

                -- Inner border (mid, 40,40,40)
                local Inner = Utility:Create("Frame", {
                    Parent           = Holder,
                    Size             = UDim2.new(1, -2, 1, -2),
                    Position         = UDim2.new(0, 1, 0, 1),
                    BackgroundColor3 = Color3.fromRGB(40, 40, 40),
                    BorderSizePixel  = 0,
                })

                -- Content bg (23,23,23)
                local Main = Utility:Create("Frame", {
                    Parent           = Inner,
                    Size             = UDim2.new(1, -2, 1, -2),
                    Position         = UDim2.new(0, 1, 0, 1),
                    BackgroundColor3 = Color3.fromRGB(23, 23, 23),
                    BorderSizePixel  = 0,
                    ClipsDescendants = true,
                })

                local TitleText = Utility:Create("TextLabel", {
