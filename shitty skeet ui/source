                    Utility:Connect(Hue.InputBegan,        function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragHue   = true; Library.Interacting = true end end)
                    Utility:Connect(AlphaFrame.InputBegan, function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragAlpha = true; Library.Interacting = true end end)

                    Utility:Connect(UserInputService.InputEnded, function(inp)
                        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragSV = false; dragHue = false; dragAlpha = false
                            Library.Interacting = false
                        end
                    end)

                    Utility:Connect(UserInputService.InputChanged, function(inp)
                        if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                        if dragSV then
                            s = math.clamp((inp.Position.X - SV.AbsolutePosition.X) / SV.AbsoluteSize.X, 0, 1)
                            v = 1 - math.clamp((inp.Position.Y - SV.AbsolutePosition.Y) / SV.AbsoluteSize.Y, 0, 1)
                            SVMarker.Position = UDim2.new(s, 0, 1 - v, 0)
                            Update()
                        elseif dragHue then
                            local y = math.clamp((inp.Position.Y - Hue.AbsolutePosition.Y) / Hue.AbsoluteSize.Y, 0, 1)
                            h = 1 - y
                            HueMarker.Position = UDim2.new(0, 0, y, 0)
                            Update()
                        elseif dragAlpha then
                            local x = math.clamp((inp.Position.X - AlphaFrame.AbsolutePosition.X) / AlphaFrame.AbsoluteSize.X, 0, 1)
                            ColorP.Alpha         = x
                            AlphaMarker.Position = UDim2.new(x, 0, 0, 0)
                            Update()
                        end
                    end)

                    Update()
                    return ColorP
                end

