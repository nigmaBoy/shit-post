                        if not ConfigSystem.Selected then return end
                        local path = "gamesense/configs/" .. ConfigSystem.Selected .. ".txt"
                        if isfile(path) then
                            local ok, decoded = pcall(function()
                                return HttpService:JSONDecode(readfile(path))
                            end)
                            if ok and decoded then
                                for flag, value in pairs(decoded) do
                                    local obj = Library.Flags[flag]
                                    if obj then
                                        if type(value) == "table" and value.R then
                                            obj:Set(Color3.new(value.R, value.G, value.B), value.Alpha)
                                        elseif type(value) == "string" and obj.Key then
                                            local parsed = parseKey(value)
                                            if parsed then obj:Set(parsed) end
                                        else
                                            obj:Set(value)
                                        end
                                    end
                                end
                            end
                        end
                    end, 1)

