                    })

                    local h, s, v = Color3.toHSV(ColorP.State)
                    local dragSV, dragHue, dragAlpha = false, false, false

                    local function Update()
                        ColorP.State                    = Color3.fromHSV(h, s, v)
                        Preview.BackgroundColor3        = ColorP.State
                        SV.BackgroundColor3             = Color3.fromHSV(h, 1, 1)
                        AlphaGradientFrame.BackgroundColor3 = ColorP.State
                        if cpProps.Callback then cpProps.Callback(ColorP.State, ColorP.Alpha) end
                        if hostFlag then
                            Library.ConfigValues[hostFlag] = {
                                R = ColorP.State.R, G = ColorP.State.G,
                                B = ColorP.State.B, Alpha = ColorP.Alpha,
                            }
                        end
                    end

                    function ColorP:Set(col, alph)
                        ColorP.State  = col
                        ColorP.Alpha  = alph or ColorP.Alpha
                        h, s, v       = Color3.toHSV(col)
                        SVMarker.Position    = UDim2.new(s, 0, 1 - v, 0)
                        HueMarker.Position   = UDim2.new(0, 0, 1 - h, 0)
                        AlphaMarker.Position = UDim2.new(ColorP.Alpha, 0, 0, 0)
                        Update()
                    end

                    function ColorP:Close()
                        ColorP.Open         = false
                        PickerFrame.Visible = false
                        Shield.Visible      = false
                        Library.CurrentPopup = nil
                        Library.Interacting  = false
                    end

                    ColorP.Frame  = PickerFrame
                    ColorP.Button = HostButton

                    Utility:Connect(HostButton.MouseButton1Click, function()
                        if Library.CurrentPopup and Library.CurrentPopup ~= ColorP then
                            Library.CurrentPopup:Close()
                        end
                        ColorP.Open = not ColorP.Open
                        if ColorP.Open then
                            Library.CurrentPopup = ColorP
                            PickerFrame.Visible  = true
                            Shield.Visible       = true
                            local absPos  = HostButton.AbsolutePosition
                            local absSize = HostButton.AbsoluteSize
                            local px = absPos.X - MainFrame.AbsolutePosition.X
                            local py = (absPos.Y - MainFrame.AbsolutePosition.Y) + absSize.Y + 4
                            if (px + 182) > MainFrame.AbsoluteSize.X then
                                px = px - (182 - absSize.X)
                            end
                            PickerFrame.Position = UDim2.new(0, px, 0, py)
                        else
                            ColorP:Close()
                        end
                    end)

