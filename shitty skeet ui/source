                        if Drop.Open then Drop:Close() else Drop:OpenMenu() end
                    end)

                    -- Auto-update player list when the game's player list changes
                    if props.AutoPlayers then
                        local function RefreshPlayers()
                            Drop.Options = {}
                            for _, p in pairs(Players:GetPlayers()) do
                                if p ~= LocalPlayer then
                                    table.insert(Drop.Options, p.Name)
                                end
                            end
                            -- Keep current selection valid, clear if they left
                            if Drop.State and not table.find(Drop.Options, Drop.State) then
                                Drop.State = Drop.Options[1] or ""
                                Label.Text = tostring(Drop.State)
                            end
                            if Drop.Open then Drop:Refresh() end
                        end

                        Utility:Connect(Players.PlayerAdded,   function() RefreshPlayers() end)
                        Utility:Connect(Players.PlayerRemoving, function() RefreshPlayers() end)
                        RefreshPlayers()
                    end

                    if props.Flag then
                        Library.Flags[props.Flag]        = Drop
                        Library.ConfigValues[props.Flag] = Drop.State
                    end

                    return Drop
                end

