                    Utility:Create("ImageLabel", {Parent = Inner, Position = UDim2.new(1, -11, 0.5, -3), Size = UDim2.new(0, 7, 0, 6), Image = "rbxassetid://8532000591", BackgroundTransparency = 1, ImageColor3 = Color3.fromRGB(255,255,255)})
                    local Button = Utility:Create("TextButton", {Parent = Frame, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 2})

                    local ListFrame = Utility:Create("Frame", {Parent = Overlay, Visible = false, Size = UDim2.new(0, 0, 0, 0), BackgroundColor3 = Color3.fromRGB(12, 12, 12), BorderSizePixel = 0, ZIndex = 50, Active = true})
                    local ListInner = Utility:Create("Frame", {Parent = ListFrame, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), BackgroundColor3 = Color3.fromRGB(35, 35, 35), BorderSizePixel = 0, ZIndex = 50})
                    Utility:Create("UIListLayout", {Parent = ListInner, SortOrder = Enum.SortOrder.LayoutOrder})

                    function Drop:Refresh()
                        for _, v in pairs(ListInner:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
                        local TotalSize = 0
                        for i, opt in pairs(Drop.Options) do
                            local OptFrame = Utility:Create("Frame", {Parent = ListInner, Size = UDim2.new(1, 0, 0, 18), BackgroundColor3 = Color3.fromRGB(35, 35, 35), BorderSizePixel = 0, ZIndex = 51})
                            local OptBtn = Utility:Create("TextButton", {Parent = OptFrame, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 52})
                            Utility:Create("TextLabel", {Parent = OptFrame, Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(1, -8, 1, 0), BackgroundTransparency = 1, Text = tostring(opt), Font = Enum.Font.Code, TextSize = 11, TextColor3 = (opt == Drop.State and Library.Accent or Color3.fromRGB(205, 205, 205)), TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 51})
                            
                            Utility:Connect(OptBtn.MouseButton1Click, function()
                                Drop:Set(opt)
                                Drop:Close()
                            end)
                            Utility:Connect(OptBtn.MouseEnter, function() OptFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40) end)
                            Utility:Connect(OptBtn.MouseLeave, function() OptFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35) end)
                            TotalSize = TotalSize + 18
                        end
                        ListFrame.Size = UDim2.new(0, Outer.AbsoluteSize.X, 0, TotalSize + 2)
                    end

                    function Drop:Set(opt)
                        Drop.State = opt
                        Label.Text = tostring(opt)
                        Drop.Callback(opt)
                        if props.Flag then Library.ConfigValues[props.Flag] = opt end
                    end

                    function Drop:OpenMenu()
                        if Library.CurrentPopup and Library.CurrentPopup ~= Drop then Library.CurrentPopup:Close() end
                        Drop.Open = true
                        Library.CurrentPopup = Drop
                        Drop:Refresh()
                        ListFrame.Visible = true
                        Shield.Visible = true
                        local AbsPos = Outer.AbsolutePosition
                        local MainPos = MainFrame.AbsolutePosition
                        ListFrame.Position = UDim2.new(0, AbsPos.X - MainPos.X, 0, (AbsPos.Y - MainPos.Y) + 21)
                        Inner.BackgroundColor3 = Color3.fromRGB(46, 46, 46)
                    end

                    function Drop:Close()
                        Drop.Open = false
                        ListFrame.Visible = false
                        Shield.Visible = false
                        Inner.BackgroundColor3 = Color3.fromRGB(36, 36, 36)
                        Library.CurrentPopup = nil
                    end
                    
                    Drop.Frame = ListFrame 
                    Drop.Button = Button
                    Utility:Connect(Button.MouseButton1Click, function() if Drop.Open then Drop:Close() else Drop:OpenMenu() end end)
                    
                    if props.Flag then
                        Library.Flags[props.Flag] = Drop
                        Library.ConfigValues[props.Flag] = Drop.State
                    end

                    return Drop
                end

                function Section:CreateColorpicker(props)
                    local Frame = Utility:Create("Frame", {Parent = Scroll, Size = UDim2.new(1, 0, 0, 20), BackgroundTransparency = 1})
                    Utility:Create("TextLabel", {Parent = Frame, Position = UDim2.new(0, 41, 0, 0), Size = UDim2.new(1, -41, 1, 0), BackgroundTransparency = 1, Text = props.Name, Font = Enum.Font.Code, TextSize = 11, TextColor3 = Color3.fromRGB(205, 205, 205), TextXAlignment = Enum.TextXAlignment.Left})
                    
                    local Button = Utility:Create("TextButton", {Parent = Frame, Position = UDim2.new(1, -38, 0, 4), Size = UDim2.new(0, 17, 0, 9), BackgroundColor3 = Color3.fromRGB(12, 12, 12), BorderSizePixel = 0, Text = "", ZIndex = 9})
                    local CP = CreateColorLogic(Button, props, props.Flag)
                    if props.Flag then Library.Flags[props.Flag] = CP end
                    return CP
                end

                function Section:CreateButton(props)
                    local Frame = Utility:Create("Frame", {Parent = Scroll, Size = UDim2.new(1, 0, 0, 24), BackgroundTransparency = 1})
                    local ButtonFrame = Utility:Create("Frame", {
                        Parent = Frame, Size = UDim2.new(1, -40, 1, -4), Position = UDim2.new(0, 20, 0, 2),
                        BackgroundColor3 = Color3.fromRGB(35, 35, 35), BorderSizePixel = 1, BorderColor3 = Color3.fromRGB(12, 12, 12)
                    })
                    
                    Utility:Create("TextLabel", {
                        Parent = ButtonFrame, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
                        Text = props.Name, Font = Enum.Font.Code, TextSize = 11, TextColor3 = Color3.fromRGB(205, 205, 205), TextXAlignment = Enum.TextXAlignment.Center
                    })

                    local Interact = Utility:Create("TextButton", {Parent = ButtonFrame, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""})
                    
                    Utility:Connect(Interact.MouseButton1Click, function() if props.Callback then props.Callback() end end)
                    Utility:Connect(Interact.MouseEnter, function() ButtonFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 45) end)
                    Utility:Connect(Interact.MouseLeave, function() ButtonFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35) end)
                end

                function Section:CreateConfigSystem()
                    local ConfigSystem = {Selected = nil}
                    
                    local SectionListLayout = Scroll:FindFirstChildOfClass("UIListLayout")
                    if SectionListLayout then SectionListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center end
                    local SectionPadding = Scroll:FindFirstChildOfClass("UIPadding")
                    if SectionPadding then SectionPadding.PaddingLeft = UDim.new(0, 0) end

                    local ConfigContainer = Utility:Create("Frame", { Parent = Scroll, Size = UDim2.new(0.75, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1 })
                    Utility:Create("UIListLayout", { Parent = ConfigContainer, Padding = UDim.new(0, 10), SortOrder = Enum.SortOrder.LayoutOrder })
                    
                    local ListOuter = Utility:Create("Frame", { Parent = ConfigContainer, Size = UDim2.new(1, 0, 0, 100), BackgroundColor3 = Color3.fromRGB(12, 12, 12), BorderSizePixel = 1, BorderColor3 = Color3.fromRGB(35, 35, 35) })
                    
                    local ListInner = Utility:Create("ScrollingFrame", { Parent = ListOuter, Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(28, 28, 28), BorderSizePixel = 0, ScrollBarThickness = 2, ScrollBarImageColor3 = Library.Accent, CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y })
                    Utility:Create("UIListLayout", {Parent = ListInner, SortOrder = Enum.SortOrder.LayoutOrder})
                    Utility:Create("UIPadding", {Parent = ListInner, PaddingTop = UDim.new(0,1), PaddingBottom = UDim.new(0,1)})
                    
                    local InputOuter = Utility:Create("Frame", { Parent = ConfigContainer, Size = UDim2.new(1, 0, 0, 18), BackgroundColor3 = Color3.fromRGB(12, 12, 12), BorderSizePixel = 0 })
                    local InputInner = Utility:Create("Frame", { Parent = InputOuter, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), BackgroundColor3 = Color3.fromRGB(36, 36, 36) })
                    local InputBox = Utility:Create("TextBox", { Parent = InputInner, Position = UDim2.new(0, 5, 0, 0), Size = UDim2.new(1, -5, 1, 0), BackgroundTransparency = 1, Text = "", Font = Enum.Font.Code, TextSize = 11, TextColor3 = Color3.fromRGB(205, 205, 205), TextXAlignment = Enum.TextXAlignment.Left, PlaceholderText = "Type a config name...", PlaceholderColor3 = Color3.fromRGB(100, 100, 100), ClearTextOnFocus = false })

                    local ButtonContainer = Utility:Create("Frame", { Parent = ConfigContainer, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1 })
                    Utility:Create("UIListLayout", {Parent = ButtonContainer, Padding = UDim.new(0, 8), HorizontalAlignment = Enum.HorizontalAlignment.Center})
                    
                    local function AddSysButton(name, callback, order)
                        local BtnFrame = Utility:Create("Frame", { Parent = ButtonContainer, LayoutOrder = order, Size = UDim2.new(1, 0, 0, 22), BackgroundColor3 = Color3.fromRGB(30, 30, 30), BorderColor3 = Color3.fromRGB(10, 10, 10), BorderSizePixel = 1 })
                        Utility:Create("TextLabel", { Parent = BtnFrame, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = name, Font = Enum.Font.Code, TextSize = 11, TextColor3 = Color3.fromRGB(205, 205, 205) })
                        local BtnInteract = Utility:Create("TextButton", {Parent = BtnFrame, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""})
                        Utility:Connect(BtnInteract.MouseEnter, function() BtnFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40) end)
                        Utility:Connect(BtnInteract.MouseLeave, function() BtnFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30) end)
                        Utility:Connect(BtnInteract.MouseButton1Click, callback)
                    end
                    
                    function ConfigSystem:Refresh()
                        for _, v in pairs(ListInner:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
                        if not isfolder("gamesense/configs") then makefolder("gamesense/configs") end
                        
                        local files = listfiles("gamesense/configs")
                        for _, file in pairs(files) do
                            local name = file:match("([^/\\]+)%.txt$")
                            if name then
                                local btn = Utility:Create("TextButton", {
                                    Parent = ListInner, Size = UDim2.new(1, 0, 0, 15), BackgroundTransparency = 1, Text = "  " .. name, Font = Enum.Font.Code, TextSize = 11,
                                    TextColor3 = (ConfigSystem.Selected == name and Library.Accent or Color3.fromRGB(205, 205, 205)), TextXAlignment = Enum.TextXAlignment.Left, BorderSizePixel = 0
                                })
                                if ConfigSystem.Selected == name then btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22); btn.BackgroundTransparency = 0 end
                                Utility:Connect(btn.MouseButton1Click, function() ConfigSystem.Selected = name; InputBox.Text = name; ConfigSystem:Refresh() end)
                            end
                        end
                    end
                    
                    AddSysButton("Load", function()
                        if not ConfigSystem.Selected then return end
                        local path = "gamesense/configs/" .. ConfigSystem.Selected .. ".txt"
                        if isfile(path) then
                            local success, decoded = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
                            if success and decoded then
                                for flag, value in pairs(decoded) do
                                    local obj = Library.Flags[flag]
                                    if obj then
                                        if type(value) == "table" and value.R then obj:Set(Color3.new(value.R, value.G, value.B), value.Alpha)
                                        elseif type(value) == "string" and obj.Key then
                                            local parsed = parseKey(value)
                                            if parsed then obj:Set(parsed) end
                                        else obj:Set(value) end
                                    end
                                end
                            end
                        end
                    end, 1)

                    AddSysButton("Save", function()
                        local name = InputBox.Text
                        if name == "" then return end
                        local data = {}
                        for flag, value in pairs(Library.ConfigValues) do data[flag] = value end
                        writefile("gamesense/configs/" .. name .. ".txt", HttpService:JSONEncode(data))
                        ConfigSystem.Selected = name
                        ConfigSystem:Refresh()
                    end, 2)

                    AddSysButton("Delete", function()
                        if ConfigSystem.Selected and isfile("gamesense/configs/" .. ConfigSystem.Selected .. ".txt") then
                            delfile("gamesense/configs/" .. ConfigSystem.Selected .. ".txt")
                            ConfigSystem.Selected = nil
                            InputBox.Text = ""
                            ConfigSystem:Refresh()
                        end
                    end, 3)

                    AddSysButton("Reset", function()
                        for flag, obj in pairs(Library.Flags) do
                            if obj.Set and obj.Default ~= nil then
                                if type(obj.Default) == "table" and obj.Default.Color then obj:Set(obj.Default.Color, obj.Default.Alpha)
                                else obj:Set(obj.Default) end
                            end
                        end
                    end, 4)
                    
                    AddSysButton("Import from clipboard", function()
                        local success, clip = pcall(function() return getclipboard and getclipboard() or "" end)
                        if success and clip ~= "" then
                             local s, decoded = pcall(function() return HttpService:JSONDecode(clip) end)
                             if s and decoded then
                                 for flag, value in pairs(decoded) do
                                    local obj = Library.Flags[flag]
                                    if obj then
                                        if type(value) == "table" and value.R then obj:Set(Color3.new(value.R, value.G, value.B), value.Alpha)
                                        elseif type(value) == "string" and obj.Key then
                                            local parsed = parseKey(value)
                                            if parsed then obj:Set(parsed) end
                                        else obj:Set(value) end
                                    end
                                end
                             end
                        end
                    end, 5)

                    AddSysButton("Export to clipboard", function()
                        local name = ConfigSystem.Selected
                        if name and isfile("gamesense/configs/" .. name .. ".txt") then
                            local content = readfile("gamesense/configs/" .. name .. ".txt")
                            if setclipboard then setclipboard(content) end
                        end
                    end, 6)

                    ConfigSystem:Refresh()
                    return ConfigSystem
                end

                function Section:CreateScriptSystem()
                    local ScriptSystem = {Selected = nil}
                    
                    local SectionListLayout = Scroll:FindFirstChildOfClass("UIListLayout")
                    if SectionListLayout then SectionListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center end
                    local SectionPadding = Scroll:FindFirstChildOfClass("UIPadding")
                    if SectionPadding then SectionPadding.PaddingLeft = UDim.new(0, 0) end

                    local ScriptContainer = Utility:Create("Frame", { Parent = Scroll, Size = UDim2.new(0.75, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1 })
                    Utility:Create("UIListLayout", { Parent = ScriptContainer, Padding = UDim.new(0, 10), SortOrder = Enum.SortOrder.LayoutOrder })
                    
                    local ListOuter = Utility:Create("Frame", { Parent = ScriptContainer, Size = UDim2.new(1, 0, 0, 200), BackgroundColor3 = Color3.fromRGB(12, 12, 12), BorderSizePixel = 1, BorderColor3 = Color3.fromRGB(35, 35, 35) })
                    
                    local ListInner = Utility:Create("ScrollingFrame", { Parent = ListOuter, Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(28, 28, 28), BorderSizePixel = 0, ScrollBarThickness = 2, ScrollBarImageColor3 = Library.Accent, CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y })
                    Utility:Create("UIListLayout", {Parent = ListInner, SortOrder = Enum.SortOrder.LayoutOrder})
                    Utility:Create("UIPadding", {Parent = ListInner, PaddingTop = UDim.new(0,1), PaddingBottom = UDim.new(0,1)})
                    
                    local ButtonContainer = Utility:Create("Frame", { Parent = ScriptContainer, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1 })
                    Utility:Create("UIListLayout", {Parent = ButtonContainer, Padding = UDim.new(0, 8), HorizontalAlignment = Enum.HorizontalAlignment.Center})
                    
                    local function AddSysButton(name, callback)
                        local BtnFrame = Utility:Create("Frame", { Parent = ButtonContainer, Size = UDim2.new(1, 0, 0, 22), BackgroundColor3 = Color3.fromRGB(30, 30, 30), BorderColor3 = Color3.fromRGB(10, 10, 10), BorderSizePixel = 1 })
                        Utility:Create("TextLabel", { Parent = BtnFrame, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = name, Font = Enum.Font.Code, TextSize = 11, TextColor3 = Color3.fromRGB(205, 205, 205) })
                        local BtnInteract = Utility:Create("TextButton", {Parent = BtnFrame, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""})
                        Utility:Connect(BtnInteract.MouseEnter, function() BtnFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40) end)
                        Utility:Connect(BtnInteract.MouseLeave, function() BtnFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30) end)
                        Utility:Connect(BtnInteract.MouseButton1Click, callback)
                    end
                    
                    function ScriptSystem:Refresh()
                        for _, v in pairs(ListInner:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
                        if not isfolder("gamesense/scripts") then makefolder("gamesense/scripts") end
                        
                        local files = listfiles("gamesense/scripts")
                        for _, file in pairs(files) do
                            local name = file:match("([^/\\]+)%.txt$") or file:match("([^/\\]+)%.lua$")
                            if name then
                                local btn = Utility:Create("TextButton", {
                                    Parent = ListInner, Size = UDim2.new(1, 0, 0, 15), BackgroundTransparency = 1, Text = "  " .. name, Font = Enum.Font.Code, TextSize = 11,
                                    TextColor3 = (ScriptSystem.Selected == file and Library.Accent or Color3.fromRGB(205, 205, 205)), TextXAlignment = Enum.TextXAlignment.Left, BorderSizePixel = 0
                                })
                                if ScriptSystem.Selected == file then btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22); btn.BackgroundTransparency = 0 end
                                Utility:Connect(btn.MouseButton1Click, function() ScriptSystem.Selected = file; ScriptSystem:Refresh() end)
                            end
                        end
                    end
                    
                    AddSysButton("Execute", function()
                        if ScriptSystem.Selected and isfile(ScriptSystem.Selected) then
                            local success, err = pcall(function() loadstring(readfile(ScriptSystem.Selected))() end)
                            if not success then warn("Script Error:", err) end
                        end
                    end)

                    AddSysButton("Refresh", function() ScriptSystem:Refresh() end)

                    ScriptSystem:Refresh()
                    return ScriptSystem
                end

                return Section
            end
            return Interface
        end
        return Page
    end
    return Window
end
