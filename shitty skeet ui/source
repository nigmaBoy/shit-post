    -- // DRAG LOGIC // --
    -- RenderStepped writes position once per frame instead of every InputChanged
    -- event, eliminating jitter and lag on high mouse polling rates.
    local Dragging   = false
    local DragOffset = Vector2.new(0, 0)

    Utility:Connect(MainFrame.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            and not Library.Interacting
            and not Library.CurrentPopup
        then
            Dragging   = true
            DragOffset = UserInputService:GetMouseLocation() - MainFrame.AbsolutePosition
        end
    end)

    Utility:Connect(UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            Dragging = false
        end
    end)

    RunService.RenderStepped:Connect(function()
        if not Dragging then return end
        local mouse = UserInputService:GetMouseLocation()
        local newX  = math.floor((mouse.X - DragOffset.X) / 2) * 2
        local newY  = math.floor((mouse.Y - DragOffset.Y) / 2) * 2
        MainFrame.Position = UDim2.fromOffset(newX, newY)
    end)

    -- Close popups when clicking outside the main frame
