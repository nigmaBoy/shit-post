            end
            local DummyObj = {}
            local Logic    = Page:CreateSharedLogic(DummyObj, DefaultLayer)
            return Logic:CreateSection(props)
        end

        -- // SHARED LOGIC (sections + widgets) // --
        function Page:CreateSharedLogic(Interface, Layer)
            Interface.Sections = {}
            Interface.LeftY    = 0
