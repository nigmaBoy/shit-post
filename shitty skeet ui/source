local Utility = {}

function Utility:Create(class, properties)
    local instance = Instance.new(class)
    for k, v in pairs(properties) do
        if k ~= "Parent" then instance[k] = v end
    end
    if properties.Parent then instance.Parent = properties.Parent end
    return instance
end

function Utility:Connect(signal, callback)
    local connection = signal:Connect(callback)
    table.insert(Library.Connections, connection)
    return connection
end

function Utility:GetTextSize(text, font, size)
    return game:GetService("TextService"):GetTextSize(text, size, font, Vector2.new(10000, 10000))
end

function Utility:IsMouseOverFrame(frame)
    if not frame or not frame.Parent or not frame.Visible then return false end
    local mouse = UserInputService:GetMouseLocation() - GuiService:GetGuiInset()
    local absPos = frame.AbsolutePosition
    local absSize = frame.AbsoluteSize
    return mouse.X >= absPos.X and mouse.X <= absPos.X + absSize.X and
           mouse.Y >= absPos.Y and mouse.Y <= absPos.Y + absSize.Y
end

-- Collision logic for Section Swapping
local function collidesWith(gui1, gui2)
    local gui1_topLeft = gui1.AbsolutePosition
    local gui1_bottomRight = gui1_topLeft + gui1.AbsoluteSize
    local gui2_topLeft = gui2.AbsolutePosition
    local gui2_bottomRight = gui2_topLeft + gui2.AbsoluteSize
    return ((gui1_topLeft.x < gui2_bottomRight.x and gui1_bottomRight.x > gui2_topLeft.x) and (gui1_topLeft.y < gui2_bottomRight.y and gui1_bottomRight.y > gui2_topLeft.y))
end

local function parseKey(keyStr)
    local s, k = pcall(function() return Enum.KeyCode[keyStr] end)
    if s and k then return k end
    s, k = pcall(function() return Enum.UserInputType[keyStr] end)
    if s and k then return k end
    return nil
end

