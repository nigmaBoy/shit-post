                    function ConfigSystem:Refresh()
                        for _, v in pairs(CfgListInner:GetChildren()) do
                            if v:IsA("TextButton") then v:Destroy() end
                        end
                        if not isfolder("gamesense/configs") then makefolder("gamesense/configs") end

                        local files = listfiles("gamesense/configs")
                        for _, file in pairs(files) do
                            local name = file:match("([^/\\]+)%.txt$")
                            if name then
                                local btn = Utility:Create("TextButton", {
                                    Parent             = CfgListInner,
                                    Size               = UDim2.new(1, 0, 0, 15),
                                    BackgroundTransparency = 1,
                                    Text               = "  " .. name,
                                    Font               = Enum.Font.Code,
                                    TextSize           = 11,
                                    TextColor3         = (ConfigSystem.Selected == name and Library.Accent or Color3.fromRGB(205, 205, 205)),
                                    TextXAlignment     = Enum.TextXAlignment.Left,
                                    BorderSizePixel    = 0,
                                })
                                if ConfigSystem.Selected == name then
                                    btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
                                    btn.BackgroundTransparency = 0
                                end
                                Utility:Connect(btn.MouseButton1Click, function()
                                    ConfigSystem.Selected = name
                                    InputBox.Text         = name
                                    ConfigSystem:Refresh()
                                end)
                            end
                        end
                    end

