-- // Utility // --
local Utility = {}

function Utility:Create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then inst[k] = v end
    end
    if props.Parent then inst.Parent = props.Parent end
    return inst
end

function Utility:Connect(signal, callback)
    local conn = signal:Connect(callback)
    table.insert(Library.Connections, conn)
    return conn
end

function Utility:GetTextSize(text, font, size)
    return TextService:GetTextSize(text, size, font, Vector2.new(10000, 10000))
end

function Utility:IsMouseOverFrame(frame)
    if not frame or not frame.Parent or not frame.Visible then return false end
    local mouse   = UserInputService:GetMouseLocation() - GuiService:GetGuiInset()
    local absPos  = frame.AbsolutePosition
    local absSize = frame.AbsoluteSize
    return  mouse.X >= absPos.X and mouse.X <= absPos.X + absSize.X
        and mouse.Y >= absPos.Y and mouse.Y <= absPos.Y + absSize.Y
end

-- Section collision detection for drag-swap logic
local function collidesWith(a, b)
    local aTL = a.AbsolutePosition
    local aBR = aTL + a.AbsoluteSize
    local bTL = b.AbsolutePosition
    local bBR = bTL + b.AbsoluteSize
    return (aTL.X < bBR.X and aBR.X > bTL.X)
       and (aTL.Y < bBR.Y and aBR.Y > bTL.Y)
end

-- Parse a saved keybind string back to Enum.KeyCode or Enum.UserInputType
local function parseKey(keyStr)
    local s, k = pcall(function() return Enum.KeyCode[keyStr] end)
    if s and k then return k end
    s, k = pcall(function() return Enum.UserInputType[keyStr] end)
    if s and k then return k end
    return nil
end

