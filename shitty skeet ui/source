                -- Line hider behind title text
                Utility:Create("Frame", {
                    Parent           = Inner,
                    ZIndex           = 5,
                    BackgroundColor3 = Color3.fromRGB(23, 23, 23),
                    Position         = UDim2.new(0, 10, 0, 0),
                    Size             = UDim2.new(0, titleTextSize.X + 5, 0, 2),
                    BorderSizePixel  = 0,
                })

                -- Scrolling content area
                local Scroll = Utility:Create("ScrollingFrame", {
                    Parent                 = Main,
                    Size                   = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    BorderSizePixel        = 0,
                    ScrollBarThickness     = 2,
                    ScrollBarImageColor3   = Color3.fromRGB(65, 65, 65),
                    AutomaticCanvasSize    = Enum.AutomaticSize.Y,
                    CanvasSize             = UDim2.new(0, 0, 0, 0),
                })
                Utility:Create("UIListLayout", {
                    Parent    = Scroll,
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    Padding   = UDim.new(0, 6),
                })
                Utility:Create("UIPadding", {
                    Parent        = Scroll,
                    PaddingTop    = UDim.new(0, 15),
                    PaddingBottom = UDim.new(0, 15),
                })

                Section.Frame = Holder
                table.insert(Interface.Sections, Section)

                -- Resize handle
                local DragImage = Utility:Create("ImageLabel", {
                    Parent             = Main,
                    BackgroundTransparency = 1,
                    BorderSizePixel    = 0,
                    Position           = UDim2.new(1, -5, 1, -5),
                    Size               = UDim2.new(0, 5, 0, 5),
                    Image              = "rbxassetid://15501723105",
                    ZIndex             = 20,
                })

                local snapGrid  = 10
                local isDragging = false
                local isMoving   = false

                -- RESIZING
                DragImage.InputBegan:Connect(function(input, gpe)
                    if gpe then return end
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

                    local startSize  = Holder.AbsoluteSize
                    local dragOrigin = UserInputService:GetMouseLocation()
                    isDragging       = true
                    Library.Interacting = true

                    local conn; conn = UserInputService.InputChanged:Connect(function(inputChange)
                        if not isDragging then return end
                        if inputChange.UserInputType ~= Enum.UserInputType.MouseMovement then return end

                        local cur    = UserInputService:GetMouseLocation()
                        local deltaX = cur.X - dragOrigin.X
                        local deltaY = cur.Y - dragOrigin.Y

                        if math.abs(deltaX) >= snapGrid or math.abs(deltaY) >= snapGrid then
                            local addX     = math.floor(deltaX / snapGrid) * snapGrid
                            local addY     = math.floor(deltaY / snapGrid) * snapGrid
                            local newW     = math.max(120, startSize.X + addX)
                            local newH     = math.max(80,  startSize.Y + addY)
                            local deltaH   = newH - Holder.Size.Y.Offset

                            if deltaH ~= 0 then
                                for _, otherSec in pairs(Interface.Sections) do
                                    if otherSec.Frame ~= Holder then
                                        local isBelow      = otherSec.Frame.Position.Y.Offset > Holder.Position.Y.Offset
                                        local isSameColumn = math.abs(otherSec.Frame.Position.X.Offset - Holder.Position.X.Offset) < 50
                                        if isBelow and isSameColumn then
                                            otherSec.Frame.Position = UDim2.new(
                                                0, otherSec.Frame.Position.X.Offset,
                                                0, otherSec.Frame.Position.Y.Offset + deltaH
                                            )
                                        end
                                    end
                                end
                            end

                            Holder.Size = UDim2.new(0, newW, 0, newH)
                        end
                    end)

                    local endConn; endConn = UserInputService.InputEnded:Connect(function(inputEnd)
                        if inputEnd.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                        isDragging          = false
                        Library.Interacting = false
                        if conn    then conn:Disconnect()    end
                        if endConn then endConn:Disconnect() end
                    end)
                end)

                -- MOVING & SWAPPING
                Holder.InputBegan:Connect(function(input, gpe)
                    if gpe then return end
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

                    local mouseLocation = UserInputService:GetMouseLocation()
                    if mouseLocation.Y - TitleText.AbsolutePosition.Y >= 25 then return end

                    local dragOrigin = UserInputService:GetMouseLocation()
                    local startPos   = { X = Holder.Position.X.Offset, Y = Holder.Position.Y.Offset }
                    isMoving            = true
                    Library.Interacting = true

                    local conn; conn = UserInputService.InputChanged:Connect(function(inputChange)
                        if not isMoving then return end
                        if inputChange.UserInputType ~= Enum.UserInputType.MouseMovement then return end

                        local cur    = UserInputService:GetMouseLocation()
                        local deltaX = cur.X - dragOrigin.X
                        local deltaY = cur.Y - dragOrigin.Y

                        if math.abs(deltaX) >= snapGrid or math.abs(deltaY) >= snapGrid then
                            local addX = math.floor(deltaX / snapGrid) * snapGrid
                            local addY = math.floor(deltaY / snapGrid) * snapGrid
                            Holder.Position = UDim2.new(0, startPos.X + addX, 0, startPos.Y + addY)

                            for _, otherSec in pairs(Interface.Sections) do
                                if otherSec.Frame == Holder then continue end
                                if collidesWith(otherSec.Frame, Holder) then
                                    local oldSize = otherSec.Frame.Size
                                    local oldPos  = otherSec.Frame.Position
                                    otherSec.Frame.Position = UDim2.new(0, startPos.X, 0, startPos.Y)
                                    otherSec.Frame.Size     = Holder.Size
                                    Holder.Size             = oldSize
                                    startPos   = { X = oldPos.X.Offset, Y = oldPos.Y.Offset }
                                    dragOrigin = cur
                                    break
                                end
                            end
                        end
                    end)

                    local endConn; endConn = UserInputService.InputEnded:Connect(function(inputEnd)
                        if inputEnd.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                        isMoving            = false
                        Library.Interacting = false
                        if conn    then conn:Disconnect()    end
                        if endConn then endConn:Disconnect() end
                    end)
                end)

